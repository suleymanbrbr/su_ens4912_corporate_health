# SUT Assistant - Environment Variables Template
# Copy this to .env (do not commit .env)

# AI Service Provider (google or openrouter)
AI_PROVIDER=google

# Your API Key (Gemini or OpenRouter)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key for Secure Authentication
JWT_SECRET_KEY=generate_a_random_secure_string_here
